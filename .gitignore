app/**/*.vvp
app/**/*.out
app/**/sim
app/**/sim.out

# ── Python cache ──────────────────────────────────────────────────────────────
**/__pycache__/
*.pyc
*.pyo

# ── IDE & OS ───────────────────────────────────────────────────────────────────
.DS_Store
.vscode/
*.swp
*.swo
*~
.idea/
*.iml

# ── Session/Temp files ─────────────────────────────────────────────────────────
*.log
